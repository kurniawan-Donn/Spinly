<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp"
        android:background="@drawable/background_login">

        <!-- Logo -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/icon"
            android:contentDescription="Logo Spinly"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="100dp" />

        <!-- Card Login -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardLogin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/ivLogo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            android:layout_marginTop="40dp"
            app:cardBackgroundColor="#CC0F3460">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="28dp"
                android:paddingBottom="28dp">

                <!-- Title -->
                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Selamat Datang di Spinly"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Subtitle -->
                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Silakan login untuk melanjutkan"
                    android:textSize="14sp"
                    android:textColor="#B0C4DE"
                    android:gravity="center"
                    android:layout_marginTop="6dp"
                    app:layout_constraintTop_toBottomOf="@id/tvWelcome"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Google Button -->
                <LinearLayout
                    android:id="@+id/btnGoogleSignIn"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_google"
                    android:layout_marginTop="28dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:outlineProvider="background"
                    android:elevation="4dp"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:src="@drawable/ic_google"
                        android:contentDescription="Google"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Masuk dengan Google"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="#111111" />

                </LinearLayout>

                <!-- OR divider row -->
                <View
                    android:id="@+id/lineLeft"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:background="#4DFFFFFF"
                    android:layout_marginEnd="12dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/tvOr"
                    app:layout_constraintTop_toTopOf="@id/tvOr"
                    app:layout_constraintBottom_toBottomOf="@id/tvOr" />

                <TextView
                    android:id="@+id/tvOr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="atau"
                    android:textSize="13sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginTop="20dp"
                    app:layout_constraintTop_toBottomOf="@id/btnGoogleSignIn"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <View
                    android:id="@+id/lineRight"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:background="#4DFFFFFF"
                    android:layout_marginStart="12dp"
                    app:layout_constraintStart_toEndOf="@id/tvOr"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvOr"
                    app:layout_constraintBottom_toBottomOf="@id/tvOr" />

                <!-- Guest Button -->
                <LinearLayout
                    android:id="@+id/btnGuest"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_guest"
                    android:layout_marginTop="20dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintTop_toBottomOf="@id/tvOr"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:outlineProvider="background"
                    android:elevation="4dp"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:src="@drawable/ic_incognito"
                        android:contentDescription="Tamu"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lanjut sebagai Tamu"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="#FFFFFF" />

                </LinearLayout>
                <!-- Info Banner -->
                <LinearLayout
                    android:id="@+id/layoutGuestInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_info_banner"
                    android:padding="12dp"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp"
                    app:layout_constraintTop_toBottomOf="@id/btnGuest"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_info"
                        android:contentDescription="Info"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tamu bisa upgrade ke akun Google tanpa kehilangan data"
                        android:textSize="12sp"
                        android:textColor="#FFFFFF"
                        android:lineSpacingMultiplier="1.3" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>